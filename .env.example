# ── Python / backend ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
BACKEND_PORT=8000

# Critic Worker — leave blank to disable alignment scoring
OPENAI_API_KEY=

# Model used by the critic (default: gpt-4o-mini)
CRITIC_MODEL=gpt-4o-mini

# Max concurrent critic LLM evaluations
CRITIC_MAX_CONCURRENT=4

# ── Frontend (Next.js) ────────────────────────────────────────────────
# These are picked up by Next.js at build time; prefix with NEXT_PUBLIC_
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
